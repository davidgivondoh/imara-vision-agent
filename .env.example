# Cloud inference API key (required for cloud fallback)
NEURA_CLOUD_API_KEY=

# App engine settings
NEURA_ENGINE_PORT=4100
NEURA_ENGINE_HOST=0.0.0.0

# Agent defaults
NEURA_AUTONOMY_LEVEL=L1
NEURA_MAX_STEPS_PER_TASK=20

# Privacy
NEURA_SYNC_ENABLED=false
NEURA_TELEMETRY=true
NEURA_PREFER_LOCAL=true

# Database
NEURA_DATABASE_PATH=./data/neura.db

# Logging
NEURA_LOG_LEVEL=info
